{
  "name": "@workspace/portal",
  "version": "2.15.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=350 server.js",
    "start": "node --max-old-space-size=350 server.js",
    "build": "echo 'no build step'",
    "serve": "node --max-old-space-size=350 server.js",
    "typecheck": "echo 'no typecheck'",
    "version:bump": "node -e \"const fs=require('fs'),p=JSON.parse(fs.readFileSync('package.json','utf8'));const[ma,mi,pa]=p.version.split('.').map(Number);p.version=ma+'.'+(mi+1)+'.0';fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');console.log('Version bumped to',p.version);\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "googleapis": "^140.0.1",
    "msedge-tts": "^1.2.1",
    "ws": "^8.18.0"
  }
}
