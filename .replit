modules = ["nodejs-20", "web", "python-base-3.13"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PARISA AI"

[[workflows.workflow]]
name = "PARISA AI"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --max-old-space-size=350 server.js"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 80
